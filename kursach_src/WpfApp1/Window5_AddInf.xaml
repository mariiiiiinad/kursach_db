<Window x:Class="WpfApp1.Window5_AddInf"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Загрузка справочников" Height="900" Width="1100">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="26" Padding="28">
            <StackPanel>
                <TextBlock Text="Администрирование" FontSize="16" Foreground="#E8DFD0" />
                <TextBlock Margin="0,10,0,0" Text="Добавление врача, поликлиники, услуги и доступного слота" FontSize="30" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBg}" CornerRadius="26" Padding="26">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Медицинская организация" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Margin="0,16,0,0" Text="Поликлиника" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Policlinic_Inf" />

                            <TextBlock Margin="0,16,0,0" Text="Врач" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Doctor_Inf" />

                            <TextBlock Margin="0,16,0,0" Text="Кабинет" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Room_Inf" />

                            <TextBlock Margin="0,16,0,0" Text="Стаж / опыт работы" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Experience_Inf" />

                            <TextBlock Margin="0,16,0,0" Text="Специализация" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Specialization_inf" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Услуга и расписание" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Margin="0,16,0,0" Text="Услуга" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Service_Inf" />

                            <TextBlock Margin="0,16,0,0" Text="Стоимость услуги" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Price_Inf" />

                            <TextBlock Margin="0,16,0,0" Text="Контактный телефон" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Number_phone" />

                            <TextBlock Margin="0,16,0,0" Text="Адрес" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="Adress_Inf" />

                            <TextBlock Margin="0,16,0,0" Text="Дата доступности" FontSize="15" FontWeight="SemiBold" />
                            <TextBox x:Name="DateTime_Inf" />
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,22,0,0" Background="#F2E8DA" CornerRadius="18" Padding="16">
                        <TextBlock Text="При сохранении создаются или обновляются связанные сущности: поликлиника, специализация, врач, услуга и слот доступности." TextWrapping="Wrap" Foreground="{StaticResource PrimaryDarkBrush}" />
                    </Border>

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Home_Button" Grid.Column="0" Click="Home_Button_Click" Content="Вернуться в центр" Style="{StaticResource OutlineButton}" />
                        <Button x:Name="BackToMain" Grid.Column="2" Click="BackToMain_Click" Content="Сохранить в систему" Background="{StaticResource AccentBrush}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
