<Window x:Class="WpfApp1.Window2_PaymentInformation"
        ResizeMode="CanMinimize"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Подтверждение записи" Height="720" Width="860">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="26" Padding="28">
            <StackPanel>
                <TextBlock Text="Финальное подтверждение" FontSize="16" Foreground="#E8DFD0" />
                <TextBlock Margin="0,10,0,0" Text="Сверьте параметры приема перед сохранением записи" FontSize="30" FontWeight="SemiBold" Foreground="White" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBg}" CornerRadius="26" Padding="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Text="Пациент" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="PatientFullName_PaymentInf" Grid.Row="0" Grid.Column="1" IsReadOnly="True" />

                <TextBlock Grid.Row="1" Text="Поликлиника" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Policlinic_PaymentInf" Grid.Row="1" Grid.Column="1" IsReadOnly="True" />

                <TextBlock Grid.Row="2" Text="Врач" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Doctor_PaymentInf" Grid.Row="2" Grid.Column="1" IsReadOnly="True" />

                <TextBlock Grid.Row="3" Text="Услуга" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Service_PaymentInf" Grid.Row="3" Grid.Column="1" IsReadOnly="True" />

                <TextBlock Grid.Row="4" Text="Дата приема" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="DateTime_PaymentInf" Grid.Row="4" Grid.Column="1" IsReadOnly="True" />

                <Border Grid.Row="5" Grid.ColumnSpan="2" Margin="0,24,0,0" Background="#F2E8DA" CornerRadius="20" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Сумма к оплате" FontSize="14" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="После подтверждения слот будет закреплен за пациентом." Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBox x:Name="FinalSum" Grid.Column="1" IsReadOnly="True" Background="{StaticResource AccentBrush}" Foreground="White" FontSize="24" FontWeight="Bold" TextAlignment="Center" BorderBrush="{x:Null}" />
                    </Grid>
                </Border>

                <Button x:Name="Payment" Grid.Row="6" Grid.Column="1" Margin="0,24,0,0" Click="ToPay" Content="Подтвердить запись" Background="{StaticResource AccentBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
