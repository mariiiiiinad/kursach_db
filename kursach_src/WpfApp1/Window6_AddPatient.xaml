<Window x:Class="WpfApp1.Window6_AddPatient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Регистрация пациента" Height="760" Width="860">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="26" Padding="28">
            <StackPanel>
                <TextBlock Text="Карточка пациента" FontSize="16" Foreground="#E8DFD0" />
                <TextBlock Margin="0,10,0,0" Text="Первичная регистрация персональных данных" FontSize="30" FontWeight="SemiBold" Foreground="White" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBg}" CornerRadius="26" Padding="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Text="ФИО" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Fio_Patient" Grid.Row="0" Grid.Column="1" />

                <TextBlock Grid.Row="1" Text="Возраст" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Age_Patient" Grid.Row="1" Grid.Column="1" />

                <TextBlock Grid.Row="2" Text="Адрес проживания" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Adress_Patient" Grid.Row="2" Grid.Column="1" />

                <TextBlock Grid.Row="3" Text="Телефон" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Number_Patient" Grid.Row="3" Grid.Column="1" />

                <TextBlock Grid.Row="4" Text="Дата рождения" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox x:Name="Bairthday_Patient" Grid.Row="4" Grid.Column="1" />

                <Grid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="Home_Button" Grid.Column="0" Click="Home_Button_Click" Content="Вернуться в центр" Style="{StaticResource OutlineButton}" />
                    <Button x:Name="BackToMain" Grid.Column="2" Click="BackToMain_Click" Content="Сохранить пациента" Background="{StaticResource AccentBrush}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
